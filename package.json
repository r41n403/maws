{
  "name": "maws",
  "version": "0.1.0",
  "description": "Maws — modular macOS toolkit for AWS architects",
  "main": "src/main/index.js",
  "author": "r41n403",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "postinstall": "electron-builder install-app-deps && node node_modules/electron/install.js",

    "build": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dir",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.600.0",
    "@aws-sdk/client-auto-scaling": "^3.600.0",
    "@aws-sdk/client-cloudfront": "^3.600.0",
    "@aws-sdk/client-cost-explorer": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-ec2": "^3.600.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.600.0",
    "@aws-sdk/client-iam": "^3.600.0",
    "@aws-sdk/client-rds": "^3.600.0",
    "@aws-sdk/client-sns": "^3.600.0",
    "@aws-sdk/client-route-53": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-sso": "^3.600.0",
    "@aws-sdk/client-sso-oidc": "^3.600.0",
    "@aws-sdk/client-sts": "^3.600.0",
    "@aws-sdk/credential-providers": "^3.600.0",
    "ini": "^7.0.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "moduleNameMapper": {
      "^electron$": "<rootDir>/tests/__mocks__/electron.js"
    }
  }
}
