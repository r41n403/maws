{
  "name": "maws",
  "productName": "MAWS",
  "version": "1.0.0",
  "description": "Maws — modular macOS toolkit for AWS architects",
  "main": "src/main/index.js",
  "author": "r41n403",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "postinstall": "electron-builder install-app-deps && node node_modules/electron/install.js && bash scripts/patch-electron-name.sh",
    "build": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dir",
    "test": "jest",
    "screenshots": "electron scripts/take-screenshots.js"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.600.0",
    "@aws-sdk/client-auto-scaling": "^3.600.0",
    "@aws-sdk/client-cloudformation": "^3.1075.0",
    "@aws-sdk/client-cloudfront": "^3.600.0",
    "@aws-sdk/client-cloudtrail": "^3.1075.0",
    "@aws-sdk/client-cloudwatch": "^3.1075.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1075.0",
    "@aws-sdk/client-cost-explorer": "^3.600.0",
    "@aws-sdk/client-detective": "^3.1075.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-ec2": "^3.600.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.600.0",
    "@aws-sdk/client-guardduty": "^3.1075.0",
    "@aws-sdk/client-iam": "^3.600.0",
    "@aws-sdk/client-identitystore": "^3.1075.0",
    "@aws-sdk/client-macie2": "^3.1075.0",
    "@aws-sdk/client-rds": "^3.600.0",
    "@aws-sdk/client-route-53": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-sns": "^3.600.0",
    "@aws-sdk/client-sso": "^3.600.0",
    "@aws-sdk/client-sso-admin": "^3.1075.0",
    "@aws-sdk/client-sso-oidc": "^3.600.0",
    "@aws-sdk/client-sts": "^3.600.0",
    "@aws-sdk/credential-providers": "^3.600.0",
    "ini": "^7.0.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "electron": "^42.6.0",
    "electron-builder": "^26.15.3",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^electron$": "<rootDir>/tests/__mocks__/electron.js"
    }
  }
}
