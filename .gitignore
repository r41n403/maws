# Dependencies
node_modules/

# Build output
dist/
out/
*.dmg
*.pkg
*.zip
*.asar

# Logs
*.log
npm-debug.log*
yarn-error.log

# Environment / secrets — never commit these
.env
.env.*
*.pem
*.key
*.p12
*.p8
*.pfx

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo

# Test artefacts
coverage/
.nyc_output/

# Runtime data — stored in ~/Library/Application Support/maws/, outside this repo.
# These patterns are listed explicitly as a safeguard in case anything ends up
# relative to the project directory during local development.
audit.log
audit.jsonl
custom-scripts.json
script-versions.json
script-logs/

# AWS credentials live in ~/.aws/ — also outside this repo.
